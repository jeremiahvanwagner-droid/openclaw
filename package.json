{
  "name": "openclaw",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "corepack pnpm -r --if-present run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:source": "eslint handlers lib inngest scripts --ext .ts --ext .js --ext .mjs --ext .cjs",
    "lint:ci": "node scripts/check-lint-warning-baseline.mjs",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dashboard:typecheck": "corepack pnpm --dir dashboard run typecheck",
    "dashboard:build": "corepack pnpm --dir dashboard run build",
    "validate": "corepack pnpm lint:ci && corepack pnpm typecheck && corepack pnpm test && corepack pnpm dashboard:build && corepack pnpm dashboard:typecheck"
  },
  "devDependencies": {
    "@types/nodemailer": "^7.0.11",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@supabase/supabase-js": "^2.39.0",
    "inngest": "^3.0.0",
    "nodemailer": "^8.0.2",
    "openai": "^4.70.0",
    "pino": "^9.0.0",
    "prom-client": "^15.1.3"
  }
}
