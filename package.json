{
  "name": "openclaw",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:source": "eslint handlers lib inngest scripts --ext .ts --ext .js --ext .mjs --ext .cjs",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate": "pnpm lint:source && pnpm typecheck && pnpm test && pnpm --dir dashboard run typecheck && pnpm --dir dashboard run build"
  },
  "devDependencies": {
    "@types/nodemailer": "^7.0.11",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@supabase/supabase-js": "^2.39.0",
    "inngest": "^3.0.0",
    "nodemailer": "^8.0.2",
    "openai": "^4.70.0",
    "pino": "^9.0.0",
    "prom-client": "^15.1.3"
  }
}
