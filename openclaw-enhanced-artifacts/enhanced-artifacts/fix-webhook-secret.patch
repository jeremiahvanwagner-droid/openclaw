#
# Or apply manually by editing handlers/ghl-webhook-handler.mjs:
#   1. Find line 87:  const WEBHOOK_SECRET = process.env.OPENCLAW_GHL_WEBHOOK_SECRET || '';
#   2. Replace with the IIFE above (lines starting with "const WEBHOOK_SECRET = (function")
#   3. Add the startup strength check after the configuredTenants block
#
# After applying:
#   - Set OPENCLAW_GHL_WEBHOOK_SECRET in /etc/systemd/system/openclaw-webhook.service
#     Environment="OPENCLAW_GHL_WEBHOOK_SECRET=<your-32+-char-secret>"
#   - Reload: systemctl daemon-reload && systemctl restart openclaw-webhook
#   - Update the corresponding GHL webhook URL to include the secret or
#     configure GHL to send the HMAC signature header
#
# Generate a strong secret:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
