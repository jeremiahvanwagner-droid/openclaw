--- a/handlers/ghl-webhook-handler.mjs
+++ b/handlers/ghl-webhook-handler.mjs
@@ -85,11 +85,40 @@ const PORT = process.env.OPENCLAW_GHL_WEBHOOK_PORT || 8788;
 const HOST = process.env.OPENCLAW_GHL_WEBHOOK_HOST || '127.0.0.1';
-const WEBHOOK_SECRET = process.env.OPENCLAW_GHL_WEBHOOK_SECRET || '';
+// SEC-03 fix: Fail fast if WEBHOOK_SECRET is missing in production.
+// An empty string bypasses HMAC authentication — any caller can forge
+// requests that pass the signature check.
+//
+// In development/test environments, set NODE_ENV=development to allow
+// running without a secret (useful for local webhook testing with ngrok).
+// In staging and production, always set OPENCLAW_GHL_WEBHOOK_SECRET.
+const WEBHOOK_SECRET = (function resolveWebhookSecret() {
+  const secret = process.env.OPENCLAW_GHL_WEBHOOK_SECRET;
+  const isProd = process.env.NODE_ENV !== 'development' && process.env.NODE_ENV !== 'test';
+
+  if (!secret || secret.trim() === '') {
+    if (isProd) {
+      // Hard fail at startup — better to refuse to start than to silently
+      // accept unauthenticated webhooks in production.
+      console.error(
+        '[FATAL] OPENCLAW_GHL_WEBHOOK_SECRET is not set. ' +
+        'All webhook HMAC authentication would be bypassed. ' +
+        'Set this environment variable and restart. ' +
+        'To run without a secret in development, set NODE_ENV=development.'
+      );
+      process.exit(1);
+    }
+    // Non-production: warn loudly but allow startup
+    console.warn(
+      '[WARN] OPENCLAW_GHL_WEBHOOK_SECRET is not set. ' +
+      'HMAC authentication is DISABLED. Only use this in local development.'
+    );
+    return '';
+  }
+
+  return secret.trim();
+}());
+
 const TELEGRAM_CHAT_ID = process.env.OPENCLAW_ALERT_TELEGRAM_CHAT_ID || '';
 const TEAMS_CHANNEL_ID = process.env.OPENCLAW_ALERT_TEAMS_CHANNEL_ID || '';
 const M365_EMAIL_OWNER = process.env.M365_EMAIL_OWNER || '';

@@ -99,6 +128,18 @@ const configuredTenants = listTenants();
 if (configuredTenants.length === 0) {
   log.fatal('No GHL tenants configured - set GHL_PRIVATE_INTEGRATION_TOKEN_* and GHL_LOCATION_ID_*');
   process.exit(1);
 }
+
+// ── Startup secret strength check ────────────────────────────────────────────
+// Warn if the secret is set but suspiciously short (min 32 chars recommended
+// for HMAC-SHA256 to have adequate entropy).
+if (WEBHOOK_SECRET && WEBHOOK_SECRET.length < 32) {
+  log.warn(
+    { secretLength: WEBHOOK_SECRET.length },
+    'OPENCLAW_GHL_WEBHOOK_SECRET is set but shorter than 32 characters. ' +
+    'Use a cryptographically random secret of at least 32 characters. ' +
+    'Generate one with: node -e "console.log(require(\'crypto\').randomBytes(32).toString(\'hex\'))"'
+  );
+}
+
+log.info({ secretConfigured: WEBHOOK_SECRET.length > 0 }, 'Webhook secret configuration loaded');

