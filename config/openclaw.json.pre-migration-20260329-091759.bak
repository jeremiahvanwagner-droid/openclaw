  "messages": {
    "ackReactionScope": "group-mentions"
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "boot-md": {
          "enabled": true
        }
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "commands": {
        "nativeSkills": false
      },
      "dmPolicy": "allowlist",
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "allowFrom": [
        "${TELEGRAM_ALERT_CHAT_ID}"
      ],
      "groupPolicy": "allowlist",
      "streaming": "off"
    },
    "msteams": {
      "enabled": false,
      "dmPolicy": "pairing",
      "groupAllowFrom": [
        "${TELEGRAM_ALERT_CHAT_ID}"
      ],
      "groupPolicy": "allowlist"
    },
    "email": {
      "enabled": true,
      "provider": "microsoft365",
      "fromAddress": "${M365_EMAIL_FROM}",
      "defaultTo": "${M365_EMAIL_OWNER}",
      "auth": {
        "tenantId": "${MSTEAMS_TENANT_ID}",
        "clientId": "${M365_EMAIL_CLIENT_ID}",
        "clientSecret": "${M365_EMAIL_CLIENT_SECRET}"
      },
      "graphApiEndpoint": "https://graph.microsoft.com/v1.0",
      "dmPolicy": "allowlist",
      "allowTo": [
        "${M365_EMAIL_OWNER}"
      ]
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_AUTH_TOKEN}"
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    },
    "nodes": {
      "denyCommands": []
    },
    "trustedProxies": [
      "127.0.0.1/32",
      "::1/128"
    ]
  },
  "skills": {
    "entries": {
      "notion": {},
      "openai-image-gen": {},
      "sag": {},
      "ghl": {
        "enabled": true,
        "config": {
          "locationId": "$env:GHL_LOCATION_ID",
