{
  "version": "1.0.0",
  "description": "Maps token groups to GHL scope sets and environment variable names. Each token group represents one GHL Private Integration.",
  "token_groups": {
    "token_insight_ops": {
      "description": "Orchestrators + Operations + Reporting agents — read-heavy, limited write (notes/logs only)",
      "scope_sets": ["read_only_insight", "operations_reporting"],
      "env_var": "GHL_TOKEN_INSIGHT_OPS_TJB",
      "tenant": "TJB",
      "ghl_integration_name": "OpenClaw – Insight & Ops",
      "rotation_days": 90
    },
    "token_marketing_nurture": {
      "description": "Marketing / Lead Nurture + Re-engagement agents",
      "scope_sets": ["lead_nurture", "re_engagement"],
      "env_var": "GHL_TOKEN_MARKETING_TJB",
      "tenant": "TJB",
      "ghl_integration_name": "OpenClaw – Marketing Nurture",
      "rotation_days": 90
    },
    "token_sales_pipeline": {
      "description": "Sales / Pipeline agents — opportunity management + calendar access",
      "scope_sets": ["sales_pipeline"],
      "env_var": "GHL_TOKEN_SALES_TJB",
      "tenant": "TJB",
      "ghl_integration_name": "OpenClaw – Sales Pipeline",
      "rotation_days": 90
    },
    "token_support_inbox": {
      "description": "Support / Inbox agents — conversation + contact access",
      "scope_sets": ["support_inbox"],
      "env_var": "GHL_TOKEN_SUPPORT_TJB",
      "tenant": "TJB",
      "ghl_integration_name": "OpenClaw – Support Inbox",
      "rotation_days": 90
    },
    "token_value_ladder": {
      "description": "Value Ladder + Community Migration agents",
      "scope_sets": ["value_ladder_ascension", "community_migration"],
      "env_var": "GHL_TOKEN_VALUE_LADDER_TJB",
      "tenant": "TJB",
      "ghl_integration_name": "OpenClaw – Value Ladder",
      "rotation_days": 90
    },
    "token_payments_readonly": {
      "description": "Payment Monitor agents — read-only finance access",
      "scope_sets": ["payment_monitor"],
      "env_var": "GHL_TOKEN_PAYMENTS_RO_TJB",
      "tenant": "TJB",
      "ghl_integration_name": "OpenClaw – Payments ReadOnly",
      "rotation_days": 90
    },
    "token_content_ops": {
      "description": "Content & Social agents — social media posting, media library, email campaigns, blogs",
      "scope_sets": ["social_media", "media_library", "email_campaigns"],
      "env_var": "GHL_TOKEN_CONTENT_OPS_TJB",
      "tenant": "TJB",
      "ghl_integration_name": "OpenClaw – Content Ops",
      "rotation_days": 90,
      "namespaces": ["socialMediaPosting", "medias", "emails", "emailIsv", "blogs"],
      "scopes": [
        "socialplanner/oauth.readonly",
        "socialplanner/post.readonly",
        "socialplanner/post.write",
        "socialplanner/account.readonly",
        "socialplanner/csv.write",
        "socialplanner/category.readonly",
        "medias.readonly",
        "medias.write",
        "emails/schedule.readonly",
        "emails/builder.readonly",
        "emails/builder.write",
        "blogs/posts.readonly",
        "blogs/post.write",
        "blogs/post-update.write",
        "blogs/list.readonly",
        "blogs/author.readonly",
        "blogs/category.readonly",
        "blogs/check-slug.readonly"
      ]
    },
    "token_saas_admin": {
      "description": "SaaS administration — sub-account provisioning, plan management, billing, rebilling",
      "scope_sets": ["saas_administration"],
      "env_var": "GHL_TOKEN_SAAS_ADMIN_TJB",
      "tenant": "TJB",
      "ghl_integration_name": "OpenClaw – SaaS Admin",
      "rotation_days": 60,
      "namespaces": ["saasApi"],
      "scopes": [
        "saas/location.write",
        "saas/location.readonly",
        "saas/company.readonly",
        "saas/company.write"
      ]
    }
  }
}
