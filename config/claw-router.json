    "note": "Sovereign tier fallback still uses a separate routing path. The OPENROUTER_API_KEY is shared across tiers during fallback only, but original tier/model assignment is preserved."
  },

  "routing_rules": [
    {
      "rule_id": "ROUTE-001",
      "priority": 1,
      "description": "Sovereign agent or tier:1 tag always routes to Tier 1 with exclusive credential",
      "match": {
        "any_of": [
          { "tag": "tier:1" },
          { "tag": "agent:sovereign" },
          { "agent_id": "sovereign" }
        ]
      },
      "route_to": "tier_1",
      "enforce_sovereign_isolation": true
    },
    {
      "rule_id": "ROUTE-002",
      "priority": 2,
      "description": "Herald or Strategist agent, or tier:2 tag routes to Tier 2",
      "match": {
        "any_of": [
          { "tag": "tier:2" },
          { "tag": "agent:herald" },
          { "tag": "agent:strategist" },
          { "agent_id": "herald" },
          { "agent_id": "strategist" }
        ]
      },
      "route_to": "tier_2",
      "enforce_sovereign_isolation": false
    },
    {
      "rule_id": "ROUTE-003",
      "priority": 3,
      "description": "Keeper or Steward agent, or tier:3 tag routes to Tier 3",
      "match": {
        "any_of": [
          { "tag": "tier:3" },
          { "tag": "agent:keeper" },
          { "tag": "agent:steward" },
          { "agent_id": "keeper" },
          { "agent_id": "steward" }
        ]
      },
      "route_to": "tier_3",
      "enforce_sovereign_isolation": false
    },
    {
      "rule_id": "ROUTE-004",
      "priority": 99,
      "description": "Default fallback — untagged tasks route to Tier 3 (cheapest safe default)",
      "match": { "default": true },
      "route_to": "tier_3",
      "enforce_sovereign_isolation": false
    }
  ],

  "security": {
    "sovereign_key_isolation": true,
    "sovereign_credential_env": "ANTHROPIC_API_KEY_SOVEREIGN",
    "shared_credential_env": "ANTHROPIC_API_KEY_AGENTS",
    "hardcoded_keys_forbidden": true,
