      "route_to": "anthropic-executor",
      "enforce_sovereign_isolation": false
    },
    {
      "rule_id": "ROUTE-COMMUNICATOR",
      "priority": 20,
      "description": "Customer-facing agents (CMO, Customer Success, Support) route to Communicator tier",
      "match": {
