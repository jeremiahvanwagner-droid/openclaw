  "routing_rules": [
    {
      "rule_id": "ROUTE-STRATEGIST",
      "priority": 1,
      "description": "Executive agents (CEO, CTO, Product Lead) route to Strategist tier with sovereign credential",
      "match": {
        "any_of": [
          { "tag": "tier:strategist" },
          { "agent_id": "d1_ceo" },
          { "agent_id": "d1_cto" },
          { "agent_id": "d1_product_dev_manager" }
