{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://truthjblue.dev/schemas/agent-config.schema.json",
  "type": "object",
  "required": ["version", "organization", "agents", "security_policy"],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "string" },
    "generated_at": { "type": "string" },
    "organization": { "type": "string" },
    "runtime_model": { "type": "string" },
    "runtime": { "type": "object" },
    "security_policy": {
      "type": "object",
      "required": ["defaults", "alias_agents", "tool_channel_map", "tool_action_family_map"],
      "properties": {
        "enforcement_modes": {
          "type": "object",
          "properties": {
            "capabilities": {
              "type": "string",
              "enum": ["off", "warn", "fail"]
            }
          },
          "additionalProperties": true
        },
        "defaults": {
          "type": "object",
          "required": ["allowed_tools", "allowed_channels", "allowed_action_families", "requires_hitl_for"],
          "properties": {
            "allowed_tools": {
              "type": "array",
              "items": { "type": "string" }
            },
            "allowed_channels": {
              "type": "array",
              "items": { "type": "string" }
            },
            "allowed_action_families": {
              "type": "array",
              "items": { "type": "string" }
            },
            "requires_hitl_for": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": true
        },
        "alias_agents": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/capabilityPolicy"
          }
        },
        "tool_channel_map": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "tool_action_family_map": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "agents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/agent"
      }
    }
  },
  "$defs": {
    "capabilityPolicy": {
      "type": "object",
      "required": ["allowed_tools", "allowed_channels", "allowed_action_families", "requires_hitl_for"],
      "properties": {
        "allowed_tools": {
          "type": "array",
          "items": { "type": "string" }
        },
        "allowed_channels": {
          "type": "array",
          "items": { "type": "string" }
        },
        "allowed_action_families": {
          "type": "array",
          "items": { "type": "string" }
        },
        "requires_hitl_for": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "agent": {
      "type": "object",
      "required": [
        "agent_id",
        "display_name",
        "org_unit",
        "role_type",
        "primary_responsibilities",
        "tools_required",
        "input_triggers",
        "output_format",
        "escalation_path",
        "llm_model",
        "memory_type",
        "workspace_path"
      ],
      "properties": {
        "agent_id": { "type": "string" },
        "display_name": { "type": "string" },
        "org_unit": { "type": "string" },
        "role_type": { "type": "string" },
        "agent_class": { "type": "string" },
        "criticality": { "type": "string" },
        "heartbeat_policy": { "type": "string" },
        "queue_class": { "type": "string" },
        "pod_id": { "type": ["string", "null"] },
        "primary_responsibilities": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tools_required": {
          "type": "array",
          "items": { "type": "string" }
        },
        "input_triggers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "output_format": { "type": "string" },
        "escalation_path": { "type": "string" },
        "llm_model": { "type": "string" },
        "memory_type": { "type": "string" },
        "inter_agent_dependencies": {
          "type": "array",
          "items": { "type": "string" }
        },
        "workspace_path": { "type": "string" },
        "cron_schedule": {
          "type": ["string", "null"]
        },
        "telegram_delivery": { "type": "boolean" },
        "teams_delivery": { "type": "boolean" },
        "reports_to": {
          "type": ["string", "null"]
        },
        "capability_policy": {
          "$ref": "#/$defs/capabilityPolicy"
        },
        "business_scope": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Business scope archetypes assigned to this agent (e.g. 'Main Orchestrator', 'Sales / Pipeline')"
        },
        "ghl_token_group": {
          "type": "string",
          "enum": [
            "token_insight_ops",
            "token_marketing_nurture",
            "token_sales_pipeline",
            "token_support_inbox",
            "token_value_ladder",
            "token_payments_readonly"
          ],
          "description": "GHL token group determining which Private Integration token and scope set this agent uses"
        },
        "operational_boundaries": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Hard operational constraints enforced at runtime (e.g. 'Never send outbound messages to contacts')"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
