# OpenClaw Caddy reverse proxy
# Place at /etc/caddy/Caddyfile on the Hetzner VPS

# Gateway API endpoint
api.truthjblue.dev {
    reverse_proxy localhost:18789

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }

    log {
        output file /var/log/caddy/api-access.log {
            roll_size 50MiB
            roll_keep 5
        }
    }
}

# Webhook endpoint
webhook.truthjblue.dev {
    reverse_proxy localhost:8788

    @notPost {
        not method POST
    }
    respond @notPost 405

    header {
        X-Content-Type-Options nosniff
        -Server
    }

    log {
        output file /var/log/caddy/webhook-access.log {
            roll_size 20MiB
            roll_keep 3
        }
    }
}

# Tailscale private gateway
http://100.84.3.71:19789 {
    reverse_proxy localhost:18789
}
