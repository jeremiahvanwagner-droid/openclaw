# OpenClaw Dashboard Environment Variables
# Copy to .env.local and fill in values

# Supabase Connection (use anon key for client-side)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Server-side only (never prefixed with NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Inngest event dispatch URL (required for agent invocation and event replay)
INNGEST_EVENT_API_URL=https://inn.gs/e/your-key
INNGEST_EVENT_KEY=your-inngest-event-key

# Comma-separated list of admin emails allowed to invoke/replay/update from the dashboard
DASHBOARD_ADMIN_EMAILS=admin@example.com

# Optional: Analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
