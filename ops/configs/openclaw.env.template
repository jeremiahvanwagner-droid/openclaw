# ============================================================================
# openclaw.env — Environment variables for OpenClaw Gateway
# Location: /opt/openclaw/.openclaw/openclaw.env
# Permissions: chmod 600 /opt/openclaw/.openclaw/openclaw.env
#
# This file is loaded by the systemd unit. All ${VAR} references in
# openclaw.json resolve from these environment variables at runtime.
# ============================================================================

# --- Gateway Auth ---
# Generate with: openssl rand -hex 32
OPENCLAW_GATEWAY_AUTH_TOKEN=

# --- Telegram ---
OPENCLAW_TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=

# --- OpenAI ---
OPENAI_API_KEY=
OPENCLAW_OPENAI_CODEX_MANUAL_TOKEN=

# --- GoHighLevel ---
GHL_PRIVATE_INTEGRATION_TOKEN=
GHL_LOCATION_ID=
GHL_EMAIL=
GHL_PASSWORD=

# --- Supabase ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Canva ---
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=
CANVA_BRAND_KIT_ID=

# --- Microsoft 365 / Email ---
MSTEAMS_TENANT_ID=
M365_EMAIL_CLIENT_ID=
M365_EMAIL_CLIENT_SECRET=
M365_EMAIL_FROM=
M365_EMAIL_OWNER=

# --- Optional ---
GDRIVE_BASE_FOLDER_ID=
YOUTUBE_CHANNEL_ID=
