# ═══════════════════════════════════════════════════════════════
# OpenClaw — Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control
# ═══════════════════════════════════════════════════════════════

# ── GoHighLevel ───────────────────────────────────────────────
# Primary integration token (Truth J Blue LLC)
GHL_PRIVATE_INTEGRATION_TOKEN=pit-your-primary-token-here
# TJB sub-account
GHL_PRIVATE_INTEGRATION_TOKEN_TJB=pit-your-tjb-token-here
GHL_LOCATION_ID_TJB=your_tjb_location_id
# MSL sub-account
GHL_PRIVATE_INTEGRATION_TOKEN_MSL=pit-your-msl-token-here
GHL_LOCATION_ID_MSL=your_msl_location_id
# GHL login (for browser automation)
GHL_EMAIL=your-email@example.com
GHL_PASSWORD=your-ghl-password
# GHL webhook verification
GHL_WEBHOOK_SECRET=your-webhook-hmac-secret

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-jwt
SUPABASE_ANON_KEY=your-supabase-anon-jwt

# ── Inngest ───────────────────────────────────────────────────
INNGEST_SIGNING_KEY=signkey-prod-your-key-here
INNGEST_EVENT_KEY=your-inngest-event-key

# ── Telegram ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_ALERT_CHAT_ID=your-chat-id

# ── OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-your-openai-key-here

# ── OpenClaw Runtime ──────────────────────────────────────────
OPENCLAW_TELEGRAM_BOT_TOKEN=your-telegram-bot-token
OPENCLAW_OPENAI_CODEX_MANUAL_TOKEN=sk-svcacct-your-codex-token
OPENCLAW_GATEWAY_AUTH_TOKEN=your-64-char-gateway-token

# ── MS Teams (optional) ──────────────────────────────────────
MSTEAMS_APP_ID=your-teams-app-id
MSTEAMS_APP_PASSWORD=your-teams-app-password
MSTEAMS_TENANT_ID=your-teams-tenant-id

# ── Microsoft 365 Email ──────────────────────────────────────
M365_EMAIL_FROM=openclaw@yourdomain.com
M365_EMAIL_OWNER=your-email@yourdomain.com
M365_EMAIL_CLIENT_ID=your-azure-app-client-id
M365_EMAIL_CLIENT_SECRET=your-azure-app-client-secret

# ── Canva (optional) ─────────────────────────────────────────
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=
CANVA_BRAND_KIT_ID=

# ── Google Drive & YouTube (optional) ────────────────────────
GDRIVE_BASE_FOLDER_ID=your-google-drive-folder-id
YOUTUBE_CHANNEL_ID=your-youtube-channel-id

# ── Webhook & Phase 3 Skills ──────────────────────────────────
# GHL token alias used by Phase 3 skill modules
GHL_TOKEN=${GHL_PRIVATE_INTEGRATION_TOKEN}
# Data directory for ebook/cart modules on VPS
OPENCLAW_DATA_DIR=/opt/openclaw/data
# Telegram alert alias used by Phase 3 skill modules (REQUIRED)
OPENCLAW_ALERT_TELEGRAM_CHAT_ID=${TELEGRAM_ALERT_CHAT_ID}
# Teams alert channel (optional)
OPENCLAW_ALERT_TEAMS_CHANNEL_ID=
# Webhook server bind address
OPENCLAW_GHL_WEBHOOK_HOST=127.0.0.1
# Webhook HMAC secret for GHL signature verification (REQUIRED)
OPENCLAW_GHL_WEBHOOK_SECRET=your-32-byte-random-webhook-secret

# ── Deployment ────────────────────────────────────────────────
ALLOWED_ORIGINS=https://your-app.com,https://app.inngest.com
OPENCLAW_GHL_WEBHOOK_PORT=8788
OPENCLAW_REPORT_TZ=America/Chicago
