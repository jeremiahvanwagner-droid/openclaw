# ═══════════════════════════════════════════════════════════════
# OpenClaw — Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control
# ═══════════════════════════════════════════════════════════════

# ── Anthropic (REQUIRED — primary AI provider) ────────────────
ANTHROPIC_API_KEY_SOVEREIGN=sk-ant-your-anthropic-key-here
ANTHROPIC_API_KEY_SHARED=sk-ant-your-anthropic-key-here

# ── Cost Guard ────────────────────────────────────────────────
# Set to true to skip real LLM calls (logs stubs instead)
DRY_RUN=false

# ── Google Gemini ───────────────────────────────────────────────
GEN_LANG_CLIENT=your-google-gen-lang-api-key-here

# ── OpenAI (EMBEDDINGS ONLY — text-embedding-3-small for semantic search) ─────
OPENAI_API_KEY=sk-proj-your-openai-key-here

# ── Redis (REQUIRED — queues, cache, session store) ─────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
# Redis password (optional, leave blank if no auth)
# REDIS_PASSWORD=

# ── Ollama (Local LLM Provider — optional, used if wired in) ─────
# Set OLLAMA_HOST to connect to local Ollama instance (Docker: http://ollama:11434)
# Leave blank to skip Ollama integration (routes to Anthropic instead)
OLLAMA_HOST=http://ollama:11434
OLLAMA_REQUEST_TIMEOUT_MS=300000
# When implemented: set OPENCLAW_LLM_PROVIDER=ollama to use local models
# OPENCLAW_LLM_PROVIDER=anthropic

# ── OpenRouter (optional fallback/model routing) ─────────────────
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here

# ── Brave Web Search (for web_search tool) ──────────────────────
BRAVE_API_KEY=your-brave-search-api-key

# ── GoHighLevel (GHL) Integration ───────────────────────────────
# Primary integration token (Truth J Blue LLC)
GHL_PRIVATE_INTEGRATION_TOKEN=pit-your-primary-token-here
# Primary GHL Location ID — used by scripts that rely on the default (TJB) tenant alias
# Must match the locationId returned by the GHL tenant resolver default
GHL_LOCATION_ID=your_primary_location_id
# TJB sub-account
GHL_PRIVATE_INTEGRATION_TOKEN_TJB=pit-your-tjb-token-here
GHL_LOCATION_ID_TJB=your_tjb_location_id
# MSL sub-account
GHL_PRIVATE_INTEGRATION_TOKEN_MSL=pit-your-msl-token-here
GHL_LOCATION_ID_MSL=your_msl_location_id
# GHL login (for browser automation)
GHL_EMAIL=your-email@example.com
GHL_PASSWORD=your-ghl-password
# GHL token alias used by Phase 3 skill modules
GHL_TOKEN=pit-your-primary-token-here

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-jwt
SUPABASE_ANON_KEY=your-supabase-anon-jwt
# Labels this runtime's rows in rate_governor_state (VPS vs workstation).
# Defaults to os.hostname() when unset.
OPENCLAW_RUNTIME_ID=

# ── Inngest ───────────────────────────────────────────────────
INNGEST_SIGNING_KEY=signkey-prod-your-key-here
INNGEST_EVENT_KEY=your-inngest-event-key

# ── Telegram ──────────────────────────────────────────────────
# REQUIRED: Telegram bot token for alert routing (auto-refresh failures, stale token alerts)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# REQUIRED: Telegram alert chat ID — default alias used by skill modules and auto-refresh
TELEGRAM_CHAT_ID=your-chat-id
TELEGRAM_ALERT_CHAT_ID=your-chat-id

# ── OpenClaw Runtime ──────────────────────────────────────────
# Cron guard: gateway.cmd refuses to start a cron-firing gateway unless this is
# 'production' (VPS) or --allow-cron is passed (audit 2026-05-16-001).
OPENCLAW_RUNTIME_ROLE=
OPENCLAW_TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# Runtime governance enforcement — accepted values: off | warn | fail
# (lib/security-governance.mjs normalizeMode; any other value silently falls back to warn).
# 'fail' (block violations) is the production default since 2026-07-04 (A4 cutover);
# use 'warn' only when staging new skills/capabilities.
OPENCLAW_CAPABILITY_ENFORCEMENT_MODE=fail
OPENCLAW_SKILL_REGISTRY_ENFORCEMENT_MODE=fail
# Browser automation data directory (Puppeteer/Playwright profile storage)
OPENCLAW_BROWSER_DATA_DIR=/opt/openclaw/browser-data
# Set to 'true' only in Docker/CI environments without a display server
OPENCLAW_BROWSER_ALLOW_UNSAFE_NO_SANDBOX=false
# Used by GHL Custom Webhook workflow actions when auth-mode=bearer
OPENCLAW_GATEWAY_AUTH_TOKEN=your-64-char-gateway-token
# Public base URL for the webhook handler used by bootstrap/smoke-test tooling
OPENCLAW_PUBLIC_WEBHOOK_BASE_URL=https://agents.yourdomain.com
# Data directory for ebook/cart modules
OPENCLAW_DATA_DIR=/opt/openclaw/data
# Telegram alert alias used by Phase 3 skill modules (REQUIRED)
OPENCLAW_ALERT_TELEGRAM_CHAT_ID=your-chat-id
# Teams alert channel (optional)
OPENCLAW_ALERT_TEAMS_CHANNEL_ID=
# Webhook server bind address
# Use 0.0.0.0 in Docker/production to accept connections from outside the container
OPENCLAW_GHL_WEBHOOK_HOST=0.0.0.0
# Shared secret for OpenClaw HMAC fallback and local webhook smoke tests
OPENCLAW_GHL_WEBHOOK_SECRET=your-32-byte-random-webhook-secret
# Optional override for GHL Ed25519 platform webhook verification.
# Leave blank to use the built-in current HighLevel public key.
OPENCLAW_GHL_WEBHOOK_PUBLIC_KEY=

# ── MS Teams (optional) ──────────────────────────────────────
MSTEAMS_APP_ID=your-teams-app-id
MSTEAMS_APP_PASSWORD=your-teams-app-password
MSTEAMS_TENANT_ID=your-teams-tenant-id

# ── Microsoft 365 Email ──────────────────────────────────────
M365_EMAIL_FROM=openclaw@yourdomain.com
M365_EMAIL_OWNER=your-email@yourdomain.com
M365_EMAIL_CLIENT_ID=your-azure-app-client-id
M365_EMAIL_CLIENT_SECRET=your-azure-app-client-secret

# ── Canva (optional) ─────────────────────────────────────────
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=
CANVA_BRAND_KIT_ID=

# ── Google Drive & YouTube (optional) ────────────────────────
GDRIVE_BASE_FOLDER_ID=your-google-drive-folder-id
YOUTUBE_CHANNEL_ID=your-youtube-channel-id

# ── Telegram Webhook ────────────────────────────────────────
# HMAC secret for verifying Telegram webhook callbacks
OPENCLAW_TELEGRAM_WEBHOOK_SECRET=your-telegram-webhook-secret

# ── Dashboard ───────────────────────────────────────────────
# Public base URL for the Next.js dashboard
OPENCLAW_DASHBOARD_BASE_URL=https://your-dashboard.vercel.app
# Comma-separated list of admin emails allowed to invoke/replay/update
DASHBOARD_ADMIN_EMAILS=admin@example.com

# ── Deployment ────────────────────────────────────────────────
ALLOWED_ORIGINS=https://your-app.com,https://app.inngest.com
OPENCLAW_GHL_WEBHOOK_PORT=8788
OPENCLAW_REPORT_TZ=America/Chicago
